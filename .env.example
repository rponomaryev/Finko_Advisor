DATABASE_URL="postgresql://postgres:postgres@localhost:5432/advisor_dev"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_REPORT_MODEL="gpt-4.1-mini"
OPENAI_RESEARCH_MODEL="gpt-4.1-mini"
OPENAI_TEST_MODEL="gpt-4.1-mini"
OPENAI_MAX_OUTPUT_TOKENS="4000"
OPENAI_REPORT_MAX_TOKENS="5000"
OPENAI_RESEARCH_MAX_TOKENS="5000"
OPENAI_WEB_SEARCH_CONTEXT_SIZE="medium"

AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

ENABLE_WEB_RESEARCH="true"
CBU_API_URL="https://cbu.uz/uz/arkhiv-kursov-valyut/json/"
MARKET_DATA_TIMEOUT_MS="5000"
OFFICIAL_DATA_TIMEOUT_MS="5000"
MARKET_DATA_CACHE_TTL_MS="21600000"
DAILY_AI_QUOTA="50"

DEMO_USER_TOKEN="demo"
DEMO_ADMIN_TOKEN="change-me-admin-token"
DEMO_SESSION_SECRET="change-me-min-32-chars"
REPORT_EXPORT_ENABLED="true"
STRICT_REPORT_LOCALE_CHECK="true"
