{
  "name": "finko-business-advisor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build-next.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-all-tests.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "test:integration": "node scripts/run-node-tests.mjs tests/integration/fullAdvisorFlow.test.ts",
    "test:e2e": "node scripts/run-node-tests.mjs tests/e2e/advisor-flow.spec.ts",
    "verify": "npm run lint && npm run typecheck && npm test && npm run test:integration && npm run test:e2e && npm run build",
    "postinstall": "node scripts/download-fonts.js",
    "test:samples": "node scripts/run-node-tests.mjs tests/businessSamplesRegistry.test.ts tests/sampleQuestionsStrictLocale.test.ts tests/sampleSpecificQuestionUniqueness.test.ts tests/interviewSemanticDeduplication.test.ts tests/bakeryRevenueReportRegression.test.ts",
    "test:locale": "node scripts/run-node-tests.mjs tests/localeStrictValidator.test.ts tests/reportLocalization.test.ts tests/reportLocalizationNoEnglishLeakage.test.ts tests/exportStrictLocaleArtifacts.test.ts tests/sampleQuestionsStrictLocale.test.ts tests/aiGeneratedQuestionPostValidation.test.ts tests/unknownBusinessAIFallback.test.ts tests/interviewProgressCompletionLocalization.test.ts",
    "test:exports": "node scripts/run-node-tests.mjs tests/pdfExport.test.ts tests/excelExport.test.ts tests/reportExportLocale.test.ts tests/reportExportRoutes.test.ts tests/exportStrictLocaleArtifacts.test.ts",
    "test:pdf": "node scripts/run-node-tests.mjs tests/pdfExport.test.ts tests/exportStrictLocaleArtifacts.test.ts",
    "test:xlsx": "node scripts/run-node-tests.mjs tests/excelExport.test.ts tests/exportStrictLocaleArtifacts.test.ts",
    "test:financial-consistency": "node scripts/run-node-tests.mjs tests/financialFormulaConsistency.test.ts tests/financialConsistencyAllBusinessModels.test.ts tests/unknownBusinessFinancialConsistency.test.ts tests/bakeryRevenueReportRegression.test.ts tests/financialCalculator.test.ts tests/scoringService.test.ts",
    "test:node": "node scripts/run-all-tests.mjs",
    "test:pdf:deps": "node scripts/check-pdf-test-deps.mjs"
  },
  "dependencies": {
    "@fontsource/noto-sans": "^5.0.0",
